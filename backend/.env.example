# BlockLancer Backend — Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://blocklancer_user:your_password@localhost:5432/blocklancer

# Server
PORT=8080
HOST=0.0.0.0

# Stacks Network
STACKS_NETWORK=testnet
HIRO_API_URL=https://api.testnet.hiro.so

# Contract Addresses (update with your deployer)
DEPLOYER_ADDRESS=your_stacks_address_here
ESCROW_CONTRACT=your_address.blocklancer-escrow-v4
DISPUTE_CONTRACT=your_address.blocklancer-dispute-v5
DAO_CONTRACT=your_address.blocklancer-dao-v3
MEMBERSHIP_CONTRACT=your_address.blocklancer-membership
PAYMENTS_CONTRACT=your_address.blocklancer-payments-v2
REPUTATION_CONTRACT=your_address.blocklancer-reputation
MARKETPLACE_CONTRACT=your_address.blocklancer-marketplace

# Bootstrap
BOOTSTRAP_BATCH_SIZE=3
BOOTSTRAP_BATCH_DELAY_MS=500

# Chainhook
CHAINHOOK_AUTH_TOKEN=your_secret_token_here
