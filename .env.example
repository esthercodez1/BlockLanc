# BlockLancer — Root Environment Variables
# Copy to .env and fill in your values
# Used by deploy scripts and infrastructure

# Deployer
DEPLOYER_ADDRESS=your_stacks_address_here
DEPLOYER_KEY=your_private_key_here

# Hiro API (get from https://platform.hiro.so)
HIRO_API_KEY=your_hiro_api_key_here

# Chainhook
CHAINHOOK_AUTH_TOKEN=your_secret_token_here

# Database
POSTGRES_USER=blocklancer_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=blocklancer
