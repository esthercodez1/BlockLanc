# BlockLancer Frontend — Environment Variables
# Copy to .env.local and fill in your values

# Network Configuration
NEXT_PUBLIC_NETWORK=testnet

# Hiro API Key (get from https://platform.hiro.so)
NEXT_PUBLIC_HIRO_API_KEY=your_hiro_api_key_here

# Deployed Contract Addresses (update with your deployer)
NEXT_PUBLIC_DAO_CONTRACT=your_address.blocklancer-dao-v3
NEXT_PUBLIC_MEMBERSHIP_CONTRACT=your_address.blocklancer-membership
NEXT_PUBLIC_DISPUTE_CONTRACT=your_address.blocklancer-dispute-v5
NEXT_PUBLIC_ESCROW_CONTRACT=your_address.blocklancer-escrow-v4
NEXT_PUBLIC_PAYMENTS_CONTRACT=your_address.blocklancer-payments-v2
NEXT_PUBLIC_REPUTATION_CONTRACT=your_address.blocklancer-reputation
NEXT_PUBLIC_MARKETPLACE_CONTRACT=your_address.blocklancer-marketplace

# App Configuration
NEXT_PUBLIC_APP_NAME=BlockLancer
NEXT_PUBLIC_APP_URL=https://blocklancing.vercel.app

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
